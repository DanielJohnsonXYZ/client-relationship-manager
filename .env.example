# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OAuth Client IDs and Secrets
# Gmail Integration
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Loom Integration
LOOM_CLIENT_ID=your_loom_client_id
LOOM_PRIVATE_KEY=your_loom_private_key

# Fireflies Integration
FIREFLIES_CLIENT_ID=your_fireflies_client_id
FIREFLIES_CLIENT_SECRET=your_fireflies_client_secret

# Zoom Integration
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret

# Slack Integration
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret

# Other Integrations
CALENDLY_CLIENT_ID=your_calendly_client_id
CALENDLY_CLIENT_SECRET=your_calendly_client_secret

# Security
JWT_SECRET=your_jwt_secret_for_tokens
WEBHOOK_SECRET=your_webhook_secret_for_verification